{
  "name": "@epdoc/colors",
  "version": "1.1.1",
  "exports": {
    ".": "./src/mod.ts",
    "./colors": "./src/colors.gen.ts",
    "./palette": "./src/colorspec.ts"
  },
  "publish": {
    "include": [
      "src",
      "deno.json",
      "README.md",
      "library-metadata.json"
    ]
  },
  "tasks": {
    "prebuild": "deno run -A ./scripts/prebuild.ts",
    "fmt": "deno task prebuild && deno fmt src test scripts *.json",
    "lint": "deno lint",
    "check": "deno check *.json src test",
    "test": "deno test -SERW",
    "docs": "deno doc --json src/mod.ts > library-docs.json",
    "ok": "deno task fmt && deno task lint && deno task check && deno task test && deno task docs"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/fmt": "jsr:@std/fmt@^1.0.10"
  }
}
