{
  "name": "@epdoc/table",
  "version": "0.1.37",
  "exports": {
    ".": "./src/mod.ts"
  },
  "publish": {
    "include": [
      "src",
      "deno.json",
      "README.md",
      "library-metadata.json"
    ]
  },
  "tasks": {
    "fmt": "deno fmt src test *.json",
    "lint": "deno lint",
    "check": "deno check *.json src test",
    "test": "deno test -SERW",
    "docs": "deno doc --json src/mod.ts > library-docs.json",
    "ok": "deno fmt && deno task lint && deno task check && deno task test && deno task docs"
  },
  "imports": {
    "@epdoc/colors": "jsr:@epdoc/colors@^1.1.2",
    "@epdoc/datetime": "jsr:@epdoc/datetime@^4.1.9",
    "@epdoc/fmt": "jsr:@epdoc/fmt@^1.0.12",
    "@epdoc/type": "jsr:@epdoc/type@^2.0.0-alpha.4",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/fmt": "jsr:@std/fmt@^1.0.10"
  }
}
