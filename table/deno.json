{
  "name": "@epdoc/table",
  "version": "0.1.10",
  "exports": {
    ".": "./src/mod.ts"
  },
  "tasks": {
    "fmt": "deno fmt src test *.json",
    "lint": "deno lint",
    "check": "deno check *.json src test",
    "test": "deno test -SERW",
    "docs": "deno doc --json src/mod.ts > library-docs.json",
    "ok": "deno fmt && deno task lint && deno task check && deno task test && deno task docs"
  },
  "imports": {
    "@epdoc/datetime": "jsr:@epdoc/datetime@^3.2.3",
    "@epdoc/duration": "jsr:@epdoc/duration@^0.3.7",
    "@epdoc/type": "jsr:@epdoc/type@^1.2.6",
    "@std/fmt": "jsr:@std/fmt@^1.0.9"
  }
}
