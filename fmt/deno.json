{
  "name": "@epdoc/fmt",
  "version": "1.0.5",
  "exports": {
    ".": "./src/mod.ts",
    "./bool": "./src/bool.ts",
    "./percent": "./src/percent.ts",
    "./bytes": "./src/bytes.ts",
    "./uptime": "./src/uptime.ts"
  },
  "publish": {
    "include": [
      "src",
      "deno.json",
      "README.md",
      "library-metadata.json"
    ]
  },
  "tasks": {
    "fmt": "deno fmt src test *.json",
    "lint": "deno lint *.json src test",
    "check": "deno check *.json src test",
    "test": "deno test -A ./test/*.test.ts",
    "docs": "deno doc --json ./src/mod.ts > library-docs.json",
    "ok": "deno fmt && deno task lint && deno task check && deno task test && deno task docs"
  },
  "imports": {
    "@epdoc/colors": "jsr:@epdoc/colors@^1.0.1",
    "@epdoc/duration": "jsr:@epdoc/duration@^0.3.14",
    "@epdoc/type": "jsr:@epdoc/type@^1.2.16",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/fmt": "jsr:@std/fmt@^1.0.10",
    "@std/testing": "jsr:@std/testing@^1.0.19"
  }
}
