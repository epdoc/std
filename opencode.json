{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "deny",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny"
    },
    "external_directory": {
      "~/dev/@epdoc/logger/**": "allow"
    },
    "webfetch": "allow",
    "bash": {
      "*": "ask",
      "*>*": "ask",
      "*|*": "ask",
      "grep *": "allow",
      "ls *": "allow",
      "git *": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git commit*": "deny",
      "git push*": "deny",
      "git tag*": "deny",
      "dtask audit*": "allow",
      "deno run *": "ask",
      "deno run *-n*": "allow",
      "deno run *--dry-run*": "allow",
      "deno test *": "allow",
      "deno task fmt*": "deny",
      "deno task lint*": "allow",
      "deno task check*": "allow",
      "deno task test*": "allow",
      "deno task *": "ask",
      "rm -rf *": "deny"
    }
  },
  "agent": {
    "plan": {
      "mode": "primary"
    },
    "build": {
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "ask",
          "*>*": "ask",
          "*|*": "ask",
          "rm -rf *": "deny",
          "git *": "allow",
          "git commit*": "ask",
          "git push*": "ask",
          "git tag*": "ask",
          "deno run *": "allow",
          "deno task fmt*": "deny",
          "deno task lint*": "allow",
          "deno task *": "allow"
        }
      }
    }
  }
}
