{
  "name": "@epdoc/datetime",
  "version": "4.1.7",
  "exports": {
    ".": "./src/mod.ts",
    "./types": "./src/types.ts"
  },
  "publish": {
    "include": [
      "src",
      "deno.json",
      "README.md",
      "library-metadata.json",
      "TEMPORAL_MIGRATION.md"
    ]
  },
  "tasks": {
    "fmt": "deno fmt src test *.json",
    "lint": "deno lint src test deno.json",
    "check": "deno check src test",
    "test": "deno test -A test",
    "docs": "deno doc --json src/mod.ts > library-docs.json",
    "ok": "deno fmt && deno task lint && deno task check && deno task test && deno task docs"
  },
  "imports": {
    "@epdoc/type": "jsr:@epdoc/type@^1.2.18",
    "@std/assert": "jsr:@std/assert@^1.0.19"
  }
}
