{
  "name": "@epdoc/progress",
  "version": "0.1.2",
  "exports": {
    ".": "./src/mod.ts"
  },
  "publish": {
    "include": [
      "src",
      "deno.json",
      "README.md",
      "library-metadata.json",
      "demo.ts"
    ]
  },
  "tasks": {
    "fmt": "deno fmt src test *.json",
    "lint": "deno lint *.json *.ts",
    "check": "deno check *.json *.ts",
    "test": "deno test -A test/*.test.ts",
    "docs": "deno doc --json ./src/mod.ts > library-docs.json",
    "ok": "deno fmt && deno task lint && deno task check && deno task test && deno task docs"
  },
  "imports": {
    "@epdoc/type": "jsr:@epdoc/type@^1.2.10",
    "@std/expect": "jsr:@std/expect@^1.0.18",
    "@std/fmt": "jsr:@std/fmt@^1.0.9",
    "@std/testing": "jsr:@std/testing@^1.0.17"
  }
}
