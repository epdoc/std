{
  "name": "@epdoc/duration",
  "version": "0.3.19",
  "description": "Duration formatting",
  "exports": {
    ".": "./src/mod.ts"
  },
  "publish": {
    "include": [
      "src",
      "deno.json",
      "README.md",
      "library-metadata.json",
      "COMPARISON.md",
      "examples"
    ]
  },
  "tasks": {
    "fmt": "deno fmt src test *.json",
    "lint": "deno lint",
    "check": "deno check src test *.json examples",
    "test": "deno test --allow-env",
    "docs": "deno doc --json src/mod.ts > library-docs.json",
    "ok": "deno fmt && deno lint && deno task check && deno task test && deno task docs"
  },
  "imports": {
    "@epdoc/type": "jsr:@epdoc/type@^2.0.0-alpha.2",
    "@std/assert": "jsr:@std/assert@^1.0.19"
  }
}
