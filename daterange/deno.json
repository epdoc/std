{
  "name": "@epdoc/daterange",
  "version": "3.0.7",
  "exports": {
    ".": "./src/mod.ts"
  },
  "publish": {
    "include": [
      "src",
      "deno.json",
      "README.md",
      "library-metadata.json"
    ]
  },
  "tasks": {
    "fmt": "deno fmt src test *.json",
    "lint": "deno lint",
    "check": "deno check *.json src test examples",
    "test": "deno test ./test/date-range.test.ts",
    "docs": "deno doc --json src/mod.ts > library-docs.json",
    "ok": "deno fmt && deno lint && deno task check && deno task test && deno task docs"
  },
  "imports": {
    "@epdoc/datetime": "jsr:@epdoc/datetime@^4.1.5",
    "@epdoc/type": "jsr:@epdoc/type@^1.2.17",
    "@std/assert": "jsr:@std/assert@^1.0.19"
  }
}
