{
  "name": "@epdoc/terminal",
  "version": "0.0.5",
  "exports": {
    ".": "./src/mod.ts",
    "./pager": "./src/pager.ts",
    "./screen": "./src/screen.ts",
    "./keys": "./src/keys.ts"
  },
  "tasks": {
    "test": "deno test -SERW",
    "lint": "deno lint",
    "check": "deno check *.json src",
    "docs": "deno doc --json src/mod.ts > library-docs.json",
    "prepublish": "deno fmt && deno task lint && deno task check && deno task test && deno task docs"
  },
  "imports": {
    "@std/fmt/colors": "jsr:@std/fmt@^1.0.9/colors"
  }
}
