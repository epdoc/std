{
  "name": "@epdoc/string",
  "version": "0.1.25",
  "exports": {
    ".": "./mod.ts"
  },
  "publish": {
    "include": [
      "mod.ts",
      "ex.ts",
      "msub.ts",
      "deno.json",
      "README.md",
      "library-metadata.json"
    ]
  },
  "tasks": {
    "fmt": "deno fmt src test *.json",
    "lint": "deno lint *.json *.ts",
    "check": "deno check *.json *.ts",
    "test": "deno test -A *.test.ts",
    "docs": "deno doc --json mod.ts > library-docs.json",
    "ok": "deno fmt && deno task lint && deno task check && deno task test && deno task docs"
  },
  "imports": {
    "@epdoc/datetime": "jsr:@epdoc/datetime@^3.2.4",
    "@epdoc/type": "jsr:@epdoc/type@^1.2.8",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/expect": "jsr:@std/expect@^1.0.18",
    "@std/testing": "jsr:@std/testing@^1.0.17"
  }
}
