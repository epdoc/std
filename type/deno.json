{
  "name": "@epdoc/type",
  "version": "2.0.0-alpha.5",
  "exports": {
    ".": "./src/mod.ts",
    "./semver": "./src/semver.ts",
    "./types": "./src/types.ts"
  },
  "publish": {
    "include": [
      "src",
      "deno.json",
      "README.md",
      "library-metadata.json"
    ]
  },
  "tasks": {
    "fmt": "deno fmt src test *.json",
    "lint": "deno lint",
    "check": "deno check *.json src test",
    "test": "deno test -SERW",
    "docs": "deno doc --json src/mod.ts > library-docs.json",
    "ok": "deno fmt && deno task lint && deno task check && deno task test && deno task docs"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19"
  }
}
