{
  "name": "@epdoc/response",
  "version": "0.1.23",
  "exports": {
    ".": "./src/mod.ts"
  },
  "publish": {
    "include": [
      "src",
      "deno.json",
      "README.md",
      "library-metadata.json"
    ]
  },
  "tasks": {
    "fmt": "deno fmt src test *.json",
    "lint": "deno lint *.json src test",
    "check": "deno check *.json src test",
    "test": "deno test -A test/*.test.ts",
    "docs": "deno doc --json ./src/mod.ts > library-docs.json",
    "ok": "deno fmt && deno task lint && deno task check && deno task test && deno task docs"
  },
  "imports": {
    "@epdoc/fs": "jsr:@epdoc/fs@^1.3.7",
    "@epdoc/type": "jsr:@epdoc/type@^1.2.13",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/expect": "jsr:@std/expect@^1.0.19",
    "@std/testing": "jsr:@std/testing@^1.0.18"
  }
}
