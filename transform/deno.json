{
  "name": "@epdoc/transform",
  "version": "2.0.0-alpha.1",
  "exports": {
    ".": "./src/mod.ts"
  },
  "publish": {
    "include": [
      "src",
      "deno.json",
      "README.md",
      "library-metadata.json"
    ]
  },
  "tasks": {
    "fmt": "deno fmt src test *.json",
    "lint": "deno lint",
    "check": "deno check *.json src test",
    "test": "deno test -SERW",
    "docs": "deno doc --json src/mod.ts > library-docs.json",
    "ok": "deno fmt && deno task lint && deno task check && deno task test && deno task docs"
  },
  "imports": {
    "@epdoc/type": "jsr:@epdoc/type@^2.0.0-alpha.1",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@std/expect": "jsr:@std/expect@^1.0.19",
    "@std/testing": "jsr:@std/testing@^1.0.19"
  }
}
