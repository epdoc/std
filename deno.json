{
  "author": {
    "name": "James Pravetz",
    "email": "jpravetz@epdoc.com"
  },
  "license": "MIT",
  "tasks": {
    "fmt": "dtask run fmt",
    "lint": "deno lint",
    "check": "deno check type datetime duration daterange fs string response",
    "test": "deno test -A",
    "docs": "deno task --cwd datetime docs && deno task --cwd type docs && deno task --cwd duration docs && deno task --cwd daterange docs && deno task --cwd fs docs && deno task --cwd string docs && deno task --cwd response docs",
    "ok": "deno fmt && deno task lint && deno task check && deno task test",
    "publish": "dtask publish",
    "update": "dtask run update"
  },
  "imports": {
    "@epdoc/duration": "jsr:@epdoc/duration@^0.3.7",
    "@epdoc/fs": "jsr:@epdoc/fs@^1.3.1",
    "@epdoc/string": "jsr:@epdoc/string@^0.1.24",
    "@epdoc/type": "jsr:@epdoc/type@^1.2.6",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/expect": "jsr:@std/expect@^1.0.18",
    "@std/fmt": "jsr:@std/fmt@^1.0.9",
    "@std/testing": "jsr:@std/testing@^1.0.17"
  },
  "fmt": {
    "singleQuote": true,
    "lineWidth": 120,
    "exclude": [
      "fs/tests/readonly",
      "fs/tests/data1",
      "fs/tests/data2"
    ]
  },
  "lint": {
    "exclude": [
      "fs/tests/readonly",
      "fs/tests/data1",
      "fs/tests/data2"
    ]
  },
  "workspace": [
    "./type",
    "./terminal",
    "./datetime",
    "./duration",
    "./progress",
    "./response",
    "./string",
    "./daterange",
    "./table",
    "./fs"
  ]
}
